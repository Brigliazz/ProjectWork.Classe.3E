<Window x:Class="BlaisePascal.ProjectWork3E.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Generatore Classi Prime" Height="680" Width="620"
    WindowStartupLocation="CenterScreen" Background="#f8fafc" FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#3b82f6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563eb"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#f1f5f9"/>
            <Setter Property="Foreground" Value="#3b82f6"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e2e8f0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="StepLabel">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#ffffff" MaxWidth="520" VerticalAlignment="Center" HorizontalAlignment="Stretch" 
            CornerRadius="12" Padding="40" Margin="40">
            <Border.Effect>
                <DropShadowEffect Color="#0f172a" Opacity="0.08" BlurRadius="20" ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Generatore Classi Prime" FontSize="26" FontWeight="Bold" 
                           Foreground="#0f172a" HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <StackPanel Margin="0,0,0,28">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="#e0e7ff" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                            <TextBlock Text="1" Foreground="#4f46e5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Inserisci Dati (File Excel)" Style="{StaticResource StepLabel}"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#f8fafc" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="8">
                            <TextBox x:Name="TxtFilePath" IsReadOnly="True" Padding="12,0" FontSize="13" 
                                     Background="Transparent" BorderThickness="0" Foreground="#334155" VerticalContentAlignment="Center" MinHeight="42" />
                        </Border>
                        <Button x:Name="BtnBrowse" Grid.Column="1" Content="Sfoglia file" Width="100" Margin="12,0,0,0" 
                                Style="{StaticResource SecondaryButton}" Click="BtnBrowse_Click" MinHeight="42" />
                    </Grid>
                </StackPanel>

                <StackPanel Margin="0,0,0,28">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="#e0e7ff" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                            <TextBlock Text="2" Foreground="#4f46e5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Elaborazione" Style="{StaticResource StepLabel}"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Gestione numero classi:" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Informatica" FontSize="11" Foreground="#64748b" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <Border Background="#f8fafc" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="8" Height="38">
                                        <TextBox x:Name="TxtClassiInformatica" Text="1" FontSize="14" FontWeight="SemiBold" TextAlignment="Center"
                                                 Background="Transparent" BorderThickness="0" Foreground="#334155" VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="3,0,3,0">
                                    <TextBlock Text="Elettronica" FontSize="11" Foreground="#64748b" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <Border Background="#f8fafc" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="8" Height="38">
                                        <TextBox x:Name="TxtClassiElettronica" Text="1" FontSize="14" FontWeight="SemiBold" TextAlignment="Center"
                                                 Background="Transparent" BorderThickness="0" Foreground="#334155" VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="6,0,0,0">
                                    <TextBlock Text="Biotecn." FontSize="11" Foreground="#64748b" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <Border Background="#f8fafc" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="8" Height="38">
                                        <TextBox x:Name="TxtClassiBiotecnologie" Text="1" FontSize="14" FontWeight="SemiBold" TextAlignment="Center"
                                                 Background="Transparent" BorderThickness="0" Foreground="#334155" VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Button x:Name="BtnImport" Grid.Column="1" Content="Importa" MinHeight="42" VerticalAlignment="Bottom"
                                Style="{StaticResource SecondaryButton}" Click="BtnImport_Click"/>
                    </Grid>

                    <ProgressBar x:Name="ProgBar" Minimum="0" Maximum="100" Height="8" Margin="0,16,0,0" 
                                 Foreground="#10b981" Background="#e2e8f0" BorderThickness="0" Visibility="Collapsed"/>

                    <TextBlock x:Name="TxtStatus" Text="Elaborazione in corso... 0%" FontSize="12" Foreground="#64748b" 
                               HorizontalAlignment="Center" Margin="0,8,0,0" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="#e0e7ff" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                            <TextBlock Text="3" Foreground="#4f46e5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Risultati" Style="{StaticResource StepLabel}"/>
                    </StackPanel>
                    <Button x:Name="BtnDownload" Content="Scarica Risultati" MinHeight="42" 
                            Style="{StaticResource SecondaryButton}"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>