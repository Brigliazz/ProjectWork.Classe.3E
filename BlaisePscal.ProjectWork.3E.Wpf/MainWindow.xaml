<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generatore Classi Prime" Height="550" Width="600"
        WindowStartupLocation="CenterScreen" Background="#f5f7fa" FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#357abd"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#ffffff" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" 
                CornerRadius="8" Padding="40" Margin="20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="30" ShadowDepth="10"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Generatore Classi Prime" FontSize="22" FontWeight="Bold" 
                           Foreground="#2c3e50" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="1. Inserisci Dati (File Excel)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" Foreground="#333333"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtFilePath" IsReadOnly="True" Padding="8" Background="#fafafa" BorderBrush="#ccc" BorderThickness="2" />
                        <Button Grid.Column="1" Content="Sfoglia..." Width="80" Margin="5,0,0,0" Style="{StaticResource PrimaryButton}" Click="BtnBrowse_Click"/>
                    </Grid>
                </StackPanel>

                <StackPanel Margin="0,0,0,25">
                    <Button x:Name="BtnGenerate" Content="2. Genera Classi" Style="{StaticResource PrimaryButton}" Click="BtnGenerate_Click"/>

                    <ProgressBar x:Name="ProgBar" Minimum="0" Maximum="100" Height="20" Margin="0,10,0,0" 
                                 Foreground="#2ecc71" Background="#e0e0e0" BorderThickness="0" Visibility="Collapsed"/>

                    <TextBlock x:Name="TxtStatus" Text="Generazione in corso... 0%" FontSize="12" Foreground="#7f8c8d" 
                               HorizontalAlignment="Center" Margin="0,5,0,0" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel>
                    <Button x:Name="BtnDownload" Content="3. Scarica Risultati" Style="{StaticResource PrimaryButton}" Click="BtnDownload_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>